# ARM CPU and peripherals require at least 16 MiB of virtual space.
CONFIG_KERNEL_VM_SIZE=0x1000000

# Platform configuration
CONFIG_ARM64_VA_BITS_36=y
CONFIG_ARM64_PA_BITS_36=y

# MMU options
CONFIG_MAX_XLAT_TABLES=16

# Serial console
CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Architectural timer
CONFIG_TIMER_READS_ITS_FREQUENCY_AT_RUNTIME=y

# The board port is intended for SMP and IPI development.
CONFIG_SMP=y
CONFIG_MP_MAX_NUM_CPUS=4

# Raspberry Pi firmware leaves the secondary cores in a spin-table loop.
CONFIG_PM_CPU_OPS=y
